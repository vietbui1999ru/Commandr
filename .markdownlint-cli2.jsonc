{
  // Loose markdown lint config — advisory only (CI job is continue-on-error).
  // Catches real breakage (broken syntax, bad links-style errors) while
  // ignoring stylistic rules that fight long-form design docs.
  "config": {
    "default": true,
    "MD013": false, // line length — design docs use long lines
    "MD033": false, // inline HTML
    "MD041": false, // first line need not be a top-level heading
    "MD024": false, // duplicate headings (changelog-style docs)
    "MD036": false, // emphasis used as heading
    "MD040": false, // fenced code blocks without language
    "MD012": false, // multiple blank lines
    "MD026": false, // trailing punctuation in headings
    "MD034": false, // bare URLs
    "MD007": false, // unordered list indentation
    "MD029": false  // ordered list numbering style
  },
  "ignores": ["node_modules/**", ".agents/**", ".claude/**"]
}
