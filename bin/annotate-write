#!/usr/bin/env bash
# annotate-write — write a per-turn annotation artifact to the bus and append a
# task_annotation event. The bus-layer writer for the annotation loop.
#
# Contract: SPEC v0.3 §14 (ANNOT-1..7), §6 (task_annotation), §2 (LAYOUT-1..3).
#   usage:  annotate-write --bus <.agents-dir> --task <id> --turn <n> \
#                          [--anchor <a>] [--author <a>] [--body <text>]
#   stdout: annotation:<path>\n on success, exit 0.
#   effect: creates <bus>/annotations/<task>/<turn>-<seq>.json (zero-padded;
#           exclusive-create; server-side seq from 0000, retries on collision up
#           to 16 — ANNOT-3/5), then appends exactly one task_annotation event to
#           <bus>/events.jsonl after the file write (ANNOT-5/7).
#   exit 1: filesystem/runtime failure.  exit 2: usage/validation error.
#
# The DiffViewer POST /annotate endpoint (and any other surface) shell to this —
# a bus artifact is bus-layer work, so the writer lives here, not in the UI.
set -u

usage() {
  printf 'usage: annotate-write --bus <dir> --task <id> --turn <n> [--anchor <a>] [--author <a>] [--body <text>]\n' >&2
  exit 2
}

bus="" task="" turn="" anchor="general" author="human" body=""
while [ $# -gt 0 ]; do
  case "$1" in
    --bus)    [ $# -ge 2 ] || usage; bus=$2;    shift 2 ;;
    --task)   [ $# -ge 2 ] || usage; task=$2;   shift 2 ;;
    --turn)   [ $# -ge 2 ] || usage; turn=$2;   shift 2 ;;
    --anchor) [ $# -ge 2 ] || usage; anchor=$2; shift 2 ;;
    --author) [ $# -ge 2 ] || usage; author=$2; shift 2 ;;
    --body)   [ $# -ge 2 ] || usage; body=$2;   shift 2 ;;
    *) usage ;;
  esac
done
[ -n "$bus" ] && [ -n "$task" ] && [ -n "$turn" ] || usage

# Task id keys a directory path and is interpolated into JSON: no whitespace,
# slashes, control or JSON-special bytes, and never . or .. (mirrors the
# discipline in bin/progress / bin/council).
case "$task" in
  '' | . | .. | */* | *[[:space:]]* | *'"'* | *'\'* )
    printf "annotate-write: invalid task id '%s'\n" "$task" >&2; exit 2 ;;
esac
printf '%s' "$task" | LC_ALL=C grep -q '[[:cntrl:]]' \
  && { printf 'annotate-write: control character in task id\n' >&2; exit 2; }

# Turn: a non-negative integer. Force base-10 so 008 etc. do not trip printf %d.
case "$turn" in '' | *[!0-9]* )
  printf 'annotate-write: turn must be a non-negative integer\n' >&2; exit 2 ;;
esac
turn=$((10#$turn))

# Bus must be an existing directory (the .agents dir).
[ -d "$bus" ] || { printf 'annotate-write: bus is not a directory: %s\n' "$bus" >&2; exit 1; }

dir="$bus/annotations/$task"
mkdir -p "$dir" || { printf 'annotate-write: cannot create %s\n' "$dir" >&2; exit 1; }

# Free text is stripped of control bytes then escaped backslash-then-quote so the
# artifact and the event line each stay one valid JSON object (EVENT-2).
esc() { local s; s=$(printf '%s' "$1" | tr -d '[:cntrl:]'); s=${s//\\/\\\\}; s=${s//\"/\\\"}; printf '%s' "$s"; }
task_e=$(esc "$task"); anchor_e=$(esc "$anchor"); author_e=$(esc "$author"); body_e=$(esc "$body")
ts=$(date -u +%Y-%m-%dT%H:%M:%SZ)

printf -v turn4 '%04d' "$turn"

record() {
  printf '{"task":"%s","turn":%d,"anchor":"%s","ts":"%s","author":"%s","body":"%s","consumed":false}\n' \
    "$task_e" "$turn" "$anchor_e" "$ts" "$author_e" "$body_e"
}

# ANNOT-3/5: exclusive-create with server-side seq. Start at the count of existing
# <turn>-*.json so the first attempt usually lands; on collision take the next seq.
# A `noclobber` redirect is O_CREAT|O_EXCL — two racers never write the same file.
seq=$(ls "$dir/$turn4-"*.json 2>/dev/null | wc -l | tr -d ' ')
start=$seq
f=""
while :; do
  printf -v seq4 '%04d' "$seq"
  f="$dir/$turn4-$seq4.json"
  if ( set -o noclobber; record > "$f" ) 2>/dev/null; then
    break
  fi
  seq=$((seq + 1))
  [ "$seq" -lt $((start + 17)) ] || {   # ANNOT-5: bounded retry (>=16 attempts)
    printf 'annotate-write: exhausted seq retries for turn %s\n' "$turn4" >&2; exit 1; }
done

# ANNOT-5/7: exactly one task_annotation event, appended AFTER the file write.
# body is intentionally absent (decision-4 fence — full content lives in the file).
printf '{"ts":"%s","event":"task_annotation","task":"%s","turn":%d,"anchor":"%s","author":"%s","seq":%d}\n' \
  "$ts" "$task_e" "$turn" "$anchor_e" "$author_e" "$seq" >> "$bus/events.jsonl" \
  || { printf 'annotate-write: event append failed\n' >&2; exit 1; }

printf 'annotation:%s\n' "$f"
exit 0
